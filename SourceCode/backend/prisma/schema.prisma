generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                   String   @id @default(uuid())
  email                String   @unique
  username             String   @unique
  password             String
  name                 String?
  createdAt            DateTime @default(now())
  profileImageUrl      String?
  notificationsEnabled Boolean  @default(true)
  posts                Posts[]
  tickets              Ticket[]
}

model Organisation {
  id                   String   @id @default(uuid())
  email                String   @unique
  password             String
  name                 String
  location             String
  createdAt            DateTime @default(now())
  profileImageUrl      String?
  evidenceImageUrl     String?
  notificationsEnabled Boolean  @default(true)
  events               Event[]
  posts                Posts[]
}

model Event {
  id                 String   @id @default(uuid())
  title              String
  description        String
  date               DateTime
  location           String
  price              Decimal  @default(0.00) @db.Decimal(10, 2)
  category           String   @default("Other")
  createdAt          DateTime @default(now())
  organiserId        String
  eventImageUrl      String?
  organiser          Organisation @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  tickets            Ticket[]
}

model Posts {
  id            String   @id @default(uuid())
  caption       String
  imageUrl      String?
  createdAt     DateTime @default(now())
  likes         Like[]
  comments      Comment[]
  studentId     String?
  organisationId String?
  student       Student?      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  organisation  Organisation? @relation(fields: [organisationId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Posts     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  postId    String
  userId    String
  post      Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model Ticket {
  id              String    @id @default(uuid())
  eventId         String
  studentId       String
  paymentIntentId String?   // Stripe PaymentIntent ID for paid events
  createdAt       DateTime  @default(now())
  used            Boolean   @default(false)
  usedAt          DateTime?

  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@index([eventId])
  @@index([studentId])
}

model Follow {
  id            String   @id @default(uuid())
  followerId    String
  followerType  String   // "STUDENT" or "ORGANISATION"
  followingId   String
  followingType String   // "STUDENT" or "ORGANISATION"
  createdAt     DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model PushToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  userRole  String   // "STUDENT" or "ORGANISATION"
  createdAt DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // "POST_LIKE", "POST_COMMENT", "TICKET_CONFIRMED", "NEW_EVENT"
  title     String
  body      String
  data      Json?    // Additional payload (eventId, postId, etc.)
  read      Boolean  @default(false)
  userId    String
  userRole  String   // "STUDENT" or "ORGANISATION"
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}