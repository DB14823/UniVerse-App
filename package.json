{
  "name": "universe",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "env:init": "bash scripts/init-env.sh",
    "install:all": "npm run env:init && cd SourceCode/frontend && npm install && cd ../backend && npm install",
    "frontend": "cd SourceCode/frontend && npx expo start",
    "frontend:tunnel": "cd SourceCode/frontend && npx expo start --tunnel",
    "backend": "cd SourceCode/backend && npm run dev",
    "dev:tunnel": "concurrently -n BACKEND,FRONTEND -c auto \"npm run backend\" \"npm run frontend:tunnel\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "patch-package": "^8.0.1",
    "prisma": "5.14.0"
  },
  "dependencies": {
    "@prisma/client": "5.14.0",
    "expo": "^55.0.15",
    "expo-dev-client": "~55.0.27",
    "expo-haptics": "^55.0.8"
  }
}
